/**
 * # validate.schema
 *
 * Provides the `Schema` class which binds a ruleset dictionary to data
 * and produces a structured validation result.
 *
 * ### Features
 *
 * - **Dot-notation keys** — `"address.city"` resolves nested dictionaries.
 * - **Wildcard keys** — `"tags.*"` validates every item in a list against
 *   a `Validator` chain.
 * - **Bail-on-first-error** per field (default) or collect-all-errors mode.
 * - **Sometimes** — skip rules when a field is absent.
 * - **Nullable** — treat nil as passing for all subsequent rules.
 * - **Label override** — substitute a human-readable name in error messages.
 * - **Required-field checking** — fields with `required()` that are entirely
 *   absent from the data dict are caught and reported.
 * - **`check(data)`** — returns `{ valid: bool, errors: list }`.
 * - **`check_or_raise(data)`** — raises `ValidationError` on failure.
 *
 * @module validate.schema
 */

import .validator { Validator }
import .rules
import reflect { get_prop, set_prop }


# ---------------------------------------------------------------------------
# ValidationError
# ---------------------------------------------------------------------------

/**
 * Raised by `Schema.check_or_raise()` when validation fails.
 *
 * The `errors` property holds the same list of `{ field, message }` dicts
 * that `Schema.check()` returns under the `errors` key.
 *
 * ```zuri
 * catch {
 *   schema.check_or_raise(req.body)
 * } as e {
 *   echo e.message   # "Validation failed"
 *   echo e.errors    # [{ field: 'email', message: '...' }, ...]
 * }
 * ```
 */
class ValidationError < Exception {
  /**
   * List of `{ field: string, message: string }` dictionaries, one per
   * failed rule.
   */
  var errors = []

  /**
   * @param list errors  Validation error list from `Schema.check()`.
   */
  ValidationError(errors) {
    parent('Validation failed.')
    self.errors = errors
  }
}


# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

# Resolve a dot-notation key path against a nested dictionary.
# Returns the value at the path, or nil when any segment is absent.
def _get_nested(data, key) {
  if !key.contains('.') {
    if is_dict(data) return data.get(key, nil)
    return nil
  }
  var parts = key.split('.')
  var cursor = data
  for part in parts {
    if !is_dict(cursor) return nil
    cursor = cursor.get(part, nil)
    if cursor == nil return nil
  }
  return cursor
}

# Returns true when a dot-notation key is present in a nested dictionary,
# even when its value is nil or false.
def _has_nested(data, key) {
  if !key.contains('.') {
    return is_dict(data) and data.contains(key)
  }
  var parts = key.split('.')
  var cursor = data
  iter var i = 0; i < parts.length() - 1; i++ {
    if !is_dict(cursor) return false
    cursor = cursor.get(parts[i], nil)
    if cursor == nil return false
  }
  var last = parts[parts.length() - 1]
  return is_dict(cursor) and cursor.contains(last)
}

# Returns true when value is nil, an empty string, or an empty list.
def _is_blank(value) {
  if value == nil return true
  if is_string(value) and value.trim().length() == 0 return true
  if is_list(value)   and value.length() == 0 return true
  return false
}

# Instantiate a rule from a [rule_class, ...args] entry with the field name
# prepended as the first argument.
def _instantiate(entry, field_name) {
  var rule_class = entry[0]
  var args = entry.length() > 1 ? entry[1,] : []

  # Build argument list: field_name first, then any additional args.
  # We use a small dispatch on arg count to avoid variadic construction.
  if args.length() == 0 return rule_class(field_name)
  if args.length() == 1 return rule_class(field_name, args[0])
  if args.length() == 2 return rule_class(field_name, args[0], args[1])
  if args.length() == 3 return rule_class(field_name, args[0], args[1], args[2])

  raise Exception('validate: rule constructor with more than 3 extra arguments is not supported')
}

# Run a single Validator chain against a value.
# Returns a list of error strings (empty when all pass).
def _run_chain(validator, field_name, value, data) {

  var errors   = []
  var nullable = false

  for entry in validator {
    var rule = _instantiate(entry, field_name)

    # Inject data when the rule requests it.
    if rule.needs_data() {
      # rule._data = data
      set_prop(rule, '_data', data)
    }

    # Nullable short-circuit: if a Nullable rule was encountered and the
    # value is nil/blank, skip all subsequent rules.
    if nullable and _is_blank(value) 
      break

    # Track whether a Nullable rule has been seen.
    if instance_of(rule, rules.Nullable) {
      nullable = true
      continue
    }

    if !rule.validate(value) {

      # If this rule wants to break out of all rules, that should happen here.
      if rule.bails_all()
        break

      errors.append(rule.error())
      if get_prop(validator, '_bail') 
        break
    }
  }

  return errors
}


# ---------------------------------------------------------------------------
# Schema
# ---------------------------------------------------------------------------

/**
 * Binds a ruleset to data and validates it.
 *
 * ### Basic usage
 *
 * ```zuri
 * import validate
 *
 * var schema = validate.schema({
 *   name:  validate.required().string().max_length(100),
 *   email: validate.required().string().email(),
 *   age:   validate.required().integer().gte(18),
 * })
 *
 * var result = schema.check({
 *   name:  'Ada Lovelace',
 *   email: 'ada@example.com',
 *   age:   36,
 * })
 *
 * echo result.valid   # true
 * echo result.errors  # []
 * ```
 *
 * ### Nested field validation (dot-notation)
 *
 * ```zuri
 * var schema = validate.schema({
 *   'address.city':    validate.required().string(),
 *   'address.country': validate.required().string().length(2).uppercase(),
 * })
 *
 * schema.check({
 *   address: { city: 'Lagos', country: 'NG' }
 * })
 * ```
 *
 * ### Wildcard list validation
 *
 * ```zuri
 * var schema = validate.schema({
 *   'tags.*': validate.required().string().max_length(32),
 * })
 *
 * schema.check({ tags: ['zuri', 'backend', 'fast'] })
 * ```
 *
 * ### Raising on failure
 *
 * ```zuri
 * catch {
 *   schema.check_or_raise(data)
 * } as e {
 *   # e.errors is a list of { field, message } dicts
 *   for err in e.errors {
 *     echo '${err.field}: ${err.message}'
 *   }
 * }
 * schema.check_or_raise(data)
 * ```
 *
 * ### Grouped errors (errors keyed by field)
 *
 * ```zuri
 * var result = schema.check(data)
 * var grouped = schema.group_errors(result.errors)
 * # { email: ['must be valid email'], age: ['must be >= 18'] }
 * ```
 */
class Schema {

  # dict: field_key → Validator instance
  var _ruleset = {}


  /**
   * @param dict ruleset  Map of field keys to `Validator` instances.
   * @throws ArgumentError  When `ruleset` is not a dictionary.
   * @throws ValueError     When a key is not a string or a value is not a
   *                        `Validator`.
   */
  Schema(ruleset) {
    if !is_dict(ruleset) {
      raise ArgumentError('Schema ruleset must be a dictionary')
    }

    ruleset = ruleset.compact()

    for key, value in ruleset {
      if !is_string(key) {
        raise ValueError('Schema ruleset keys must be strings')
      }
      if !instance_of(value, Validator) {
        raise ValueError(
          'Schema ruleset values must be Validator instances; ' +
          'got ${type_of(value)} for key "${key}"'
        )
      }
    }

    self._ruleset = ruleset
  }


  # -------------------------------------------------------------------------
  # Public API
  # -------------------------------------------------------------------------

  /**
   * Validates `data` against the schema and returns a result dictionary.
   *
   * The result always has the shape:
   *
   * ```
   * {
   *   valid:  bool,
   *   errors: list<{ field: string, message: string }>
   * }
   * ```
   *
   * Fields present in the data but absent from the schema are silently
   * ignored.  Fields present in the schema but absent from the data are
   * validated against their rules (the `required` rule catches absent
   * fields; all other rules skip nil values unless chained after
   * `required`).
   *
   * @param  dict data
   * @returns dict
   * @throws ArgumentError
   */
  check(data) {
    if !is_dict(data) {
      raise ArgumentError('Schema.check() expects a dictionary')
    }

    var errors = []

    for field_key, validator in self._ruleset {

      # Wildcard expansion: "field.*" validates each item of a list.
      if field_key.ends_with('.*') {
        var base_key = field_key[0, field_key.length() - 2]
        var list_val = _get_nested(data, base_key)

        if is_list(list_val) {
          iter var i = 0; i < list_val.length(); i++ {
            var item_key   = '${base_key}.${i}'
            var item_value = list_val[i]

            var label      = get_prop(validator, '_label') ? 
              get_prop(validator, '_label') : 
              item_key

            if get_prop(validator, '_sometimes') and _is_blank(item_value) 
              continue

            var field_errors = _run_chain(validator, label, item_value, data)
            for msg in field_errors {
              errors.append({ field: item_key, message: msg })
            }
          }
        } else {
          # Base list absent — treat as absent field; required() catches it.
          var label = get_prop(validator, '_label') ? 
            get_prop(validator, '_label') : 
            base_key

          if get_prop(validator, '_sometimes') 
            continue

          var field_errors = _run_chain(validator, label, nil, data)

          for msg in field_errors {
            errors.append({ field: base_key, message: msg })
          }
        }

        continue
      }

      # Regular field (including dot-notation paths).
      var field_present = _has_nested(data, field_key)
      var field_value   = _get_nested(data, field_key)
      var label         = get_prop(validator, '_label') ? get_prop(validator, '_label') : field_key

      # `sometimes`: skip entirely when absent.
      if get_prop(validator, '_sometimes') and (!field_present or _is_blank(field_value)) 
        continue

      var field_errors = _run_chain(validator, label, field_value, data)
      for msg in field_errors {
        errors.append({ field: field_key, message: msg })
      }
    }

    return {
      valid:  errors.is_empty(),
      errors: errors,
    }
  }

  /**
   * Validates `data` and raises a `ValidationError` if validation fails.
   * Returns the result dictionary on success.
   *
   * ```zuri
   * catch {
   *   schema.check_or_raise(req.body)
   * } as e {
   *   return res.json({ errors: e.errors }, 422)
   * }
   * ```
   *
   * @param  dict data
   * @returns dict
   * @throws ValidationError
   * @throws ArgumentError
   */
  check_or_raise(data) {
    var result = self.check(data)
    if !result.valid {
      raise ValidationError(result.errors)
    }

    return result
  }

  /**
   * Converts a flat errors list (as returned by `check`) into a dictionary
   * keyed by field name, where each value is a list of error message strings.
   *
   * ```zuri
   * var result  = schema.check(data)
   * var grouped = schema.group_errors(result.errors)
   * # { 'email': ['must be a valid email address'], 'age': ['must be >= 18'] }
   * ```
   *
   * @param  list errors  The `errors` list from a `check()` result.
   * @returns dict
   */
  group_errors(errors) {
    var grouped = {}
    for err in errors {
      var field = err.field
      if !grouped.contains(field) {
        grouped[field] = []
      }

      grouped[field].append(err.message)
    }

    return grouped
  }

  /**
   * Returns the first error message for the given field, or nil when that
   * field has no errors in the provided errors list.
   *
   * ```zuri
   * var result = schema.check(data)
   * var msg    = schema.first_error(result.errors, 'email')
   * ```
   *
   * @param  list   errors      The `errors` list from a `check()` result.
   * @param  string field_key   The field to look up.
   * @returns string|nil
   */
  first_error(errors, field_key) {
    for err in errors {
      if err.field == field_key 
        return err.message
    }

    return nil
  }

  /**
   * Returns all error messages for the given field as a list, or an empty
   * list when that field has no errors.
   *
   * @param  list   errors
   * @param  string field_key
   * @returns list<string>
   */
  field_errors(errors, field_key) {
    var out = []
    for err in errors {
      if err.field == field_key 
        out.append(err.message)
    }

    return out
  }

  /**
   * Returns `true` when the given field has at least one error in the
   * provided errors list.
   *
   * @param  list   errors
   * @param  string field_key
   * @returns bool
   */
  has_error(errors, field_key) {
    for err in errors {
      if err.field == field_key 
        return true
    }

    return false
  }

  /**
   * Extends this schema with additional rules from another schema or a plain
   * ruleset dictionary, returning a new `Schema` instance.  Rules in
   * `other` override rules for the same field key.
   *
   * ```zuri
   * var base   = validate.schema({ name: validate.required().string() })
   * var extended = base.extend({
   *   email: validate.required().string().email(),
   * })
   * ```
   *
   * @param  dict|Schema other
   * @returns Schema
   */
  extend(other) {
    var merged = {}
    for k, v in self._ruleset { merged[k] = v }

    if instance_of(other, Schema) {
      for k, v in other._ruleset { 
        merged[k] = v 
      }
    } else if is_dict(other) {
      for k, v in other { 
        merged[k] = v 
      }
    } else {
      raise ArgumentError('Schema.extend() expects a Schema or a dictionary')
    }

    return Schema(merged)
  }

  /**
   * Returns a new `Schema` containing only the rules for the given field
   * keys.
   *
   * ```zuri
   * var partial = full_schema.only(['name', 'email'])
   * ```
   *
   * @param  list keys
   * @returns Schema
   */
  only(keys) {
    var subset = {}
    for k in keys {
      if self._ruleset.contains(k) {
        subset[k] = self._ruleset[k]
      }
    }

    return Schema(subset)
  }

  /**
   * Returns a new `Schema` with the rules for the given field keys removed.
   *
   * ```zuri
   * var without_admin = schema.except(['role', 'is_superuser'])
   * ```
   *
   * @param  list keys
   * @returns Schema
   */
  except(keys) {
    var subset = {}
    for k, v in self._ruleset {
      if !keys.contains(k) {
        subset[k] = v
      }
    }

    return Schema(subset)
  }
}
