/**
 * test_crypto.zu
 *
 * Comprehensive test suite for the crypto standard library module.
 *
 * Run:
 *   zuri test_crypto.zu
 *
 * All tests use the built-in `assert` statement.  A failed assertion
 * prints "Illegal State" and the failing line; a passing run prints a
 * summary line for each group and exits 0.
 *
 * Test groups:
 *   1.  random_bytes
 *   2.  AES-GCM  (encrypt / decrypt / AAD / tamper detection)
 *   3.  AES-CBC  (encrypt / decrypt / wrong-key detection)
 *   4.  ChaCha20-Poly1305  (encrypt / decrypt / AAD / tamper detection)
 *   5.  RSA-2048 (generate / OAEP encrypt-decrypt / PSS sign-verify)
 *   6.  RSA-4096 (generate / sign-verify)
 *   7.  ECDSA P-256 (generate / sign / verify / reject wrong message)
 *   8.  ECDSA P-384 (generate / sign / verify)
 *   9.  Ed25519  (generate / sign / verify / reject wrong message)
 *   10. X25519   (generate / exchange symmetry / wrong key mismatch)
 *   11. Argon2id (hash / verify / reject wrong password / options)
 *   12. HKDF     (determinism / length / salt sensitivity)
 *   13. Cross-primitive integration (X25519 → HKDF → AES-GCM)
 *   14. Error / invalid-argument handling
 */

import crypto


# ---------------------------------------------------------------------------
# Tiny test runner — tracks pass/fail counts, prints per-group summaries.
# ---------------------------------------------------------------------------

var _passed = 0
var _failed = 0
var _group  = ''

def begin(name) {
  _group = name
}

def ok(label) {
  _passed++
  echo '  [PASS] ' + label
}

def summary() {
  echo '\n  ── ' + _group + ' ──'
}

# Asserts that calling fn() raises any exception.
# Returns true if an exception was raised, false if fn completed normally.
def raises(fn) {
  catch {
    return true
  } as e
  fn()
  return false
}

# Asserts that two byte strings have identical content.
def bytes_equal(a, b) {
  if a.length() != b.length() return false
  iter var i = 0; i < a.length(); i++ {
    if a[i] != b[i] return false
  }
  return true
}

echo '═══════════════════════════════════════════════════════'
echo '  crypto module — test suite'
echo '═══════════════════════════════════════════════════════'


# ===========================================================================
# 1. random_bytes
# ===========================================================================
begin('random_bytes')
summary()

var rb_a = crypto.random_bytes(16)
var rb_b = crypto.random_bytes(16)
var rb_c = crypto.random_bytes(32)
var rb_d = crypto.random_bytes(1)
var rb_e = crypto.random_bytes(65536)

assert rb_a.length() == 16,
  'random_bytes(16) must return exactly 16 bytes'
ok('length == 16')

assert rb_c.length() == 32,
  'random_bytes(32) must return exactly 32 bytes'
ok('length == 32')

assert rb_d.length() == 1,
  'random_bytes(1) must return exactly 1 byte'
ok('length == 1')

assert rb_e.length() == 65536,
  'random_bytes(65536) must return exactly 65536 bytes'
ok('length == 65536 (maximum)')

# Two independent calls should produce different output.
# The probability of a collision in 16 random bytes is 1/2^128 ≈ 0.
assert !bytes_equal(rb_a, rb_b),
  'Two independent random_bytes(16) calls must differ'
ok('successive calls are distinct')


# ===========================================================================
# 2. AES-GCM
# ===========================================================================
begin('AES-GCM')
summary()

var gcm_pt   = 'the quick brown fox jumps over the lazy dog'.to_bytes()
var gcm_key  = crypto.random_bytes(32)   # AES-256
var gcm_key2 = crypto.random_bytes(32)
var gcm_iv   = crypto.random_bytes(12)
var gcm_iv2  = crypto.random_bytes(12)

# Basic round-trip
var gcm_ct = crypto.aes_gcm.encrypt(gcm_key, gcm_iv, gcm_pt)
var gcm_rt = crypto.aes_gcm.decrypt(gcm_key, gcm_iv, gcm_ct)

assert bytes_equal(gcm_rt, gcm_pt),
  'AES-GCM round-trip must recover plaintext'
ok('round-trip (AES-256-GCM)')

# Ciphertext must carry a 16-byte tag, so it must be longer than plaintext
assert gcm_ct.length() == gcm_pt.length() + 16,
  'AES-GCM ciphertext must be plaintext_len + 16 (tag)'
ok('ciphertext length == plaintext + 16')

# Ciphertext must not equal plaintext
assert !bytes_equal(gcm_ct, gcm_pt),
  'AES-GCM ciphertext must differ from plaintext'
ok('ciphertext != plaintext')

# AES-128 key
var gcm_key128 = crypto.random_bytes(16)
var gcm_ct128  = crypto.aes_gcm.encrypt(gcm_key128, gcm_iv, gcm_pt)
var gcm_rt128  = crypto.aes_gcm.decrypt(gcm_key128, gcm_iv, gcm_ct128)
assert bytes_equal(gcm_rt128, gcm_pt),
  'AES-128-GCM round-trip must recover plaintext'
ok('round-trip (AES-128-GCM)')

# AES-192 key
var gcm_key192 = crypto.random_bytes(24)
var gcm_ct192  = crypto.aes_gcm.encrypt(gcm_key192, gcm_iv, gcm_pt)
var gcm_rt192  = crypto.aes_gcm.decrypt(gcm_key192, gcm_iv, gcm_ct192)
assert bytes_equal(gcm_rt192, gcm_pt),
  'AES-192-GCM round-trip must recover plaintext'
ok('round-trip (AES-192-GCM)')

# Different IV produces different ciphertext
var gcm_ct_iv2 = crypto.aes_gcm.encrypt(gcm_key, gcm_iv2, gcm_pt)
assert !bytes_equal(gcm_ct, gcm_ct_iv2),
  'Different IVs must produce different ciphertexts'
ok('distinct ciphertexts for distinct IVs')

# AAD: correct AAD decrypts successfully
var gcm_aad = 'user-id:42|resource:invoice'.to_bytes()
var gcm_ct_aad = crypto.aes_gcm.encrypt(gcm_key, gcm_iv, gcm_pt, gcm_aad)
var gcm_rt_aad = crypto.aes_gcm.decrypt(gcm_key, gcm_iv, gcm_ct_aad, gcm_aad)
assert bytes_equal(gcm_rt_aad, gcm_pt),
  'AES-GCM with AAD must recover plaintext when AAD matches'
ok('AAD — correct AAD decrypts cleanly')

# AAD: wrong AAD must fail authentication
assert raises(@() {
  crypto.aes_gcm.decrypt(gcm_key, gcm_iv, gcm_ct_aad, 'wrong-aad'.to_bytes())
}), 'AES-GCM must reject mismatched AAD'
ok('AAD — wrong AAD raises exception')

# Tampered ciphertext must fail
var gcm_tampered = gcm_ct.clone()
gcm_tampered[0] = gcm_tampered[0] ^ 0xff    # flip all bits in first byte
assert raises(@() {
  crypto.aes_gcm.decrypt(gcm_key, gcm_iv, gcm_tampered)
}), 'AES-GCM must reject tampered ciphertext'
ok('tampered ciphertext raises exception')

# Wrong key must fail
assert raises(@() {
  crypto.aes_gcm.decrypt(gcm_key2, gcm_iv, gcm_ct)
}), 'AES-GCM must reject wrong key'
ok('wrong key raises exception')

# Empty plaintext is valid
var gcm_empty_ct = crypto.aes_gcm.encrypt(gcm_key, gcm_iv, bytes(0))
var gcm_empty_rt = crypto.aes_gcm.decrypt(gcm_key, gcm_iv, gcm_empty_ct)
assert gcm_empty_rt.length() == 0,
  'AES-GCM must handle empty plaintext'
ok('empty plaintext round-trip')


# ===========================================================================
# 3. AES-CBC
# ===========================================================================
begin('AES-CBC')
summary()

var cbc_pt   = 'interoperability payload — AES CBC mode test'.to_bytes()
var cbc_key  = crypto.random_bytes(32)
var cbc_key2 = crypto.random_bytes(32)
var cbc_iv   = crypto.random_bytes(16)

# Basic round-trip
var cbc_ct = crypto.aes_cbc.encrypt(cbc_key, cbc_iv, cbc_pt)
var cbc_rt = crypto.aes_cbc.decrypt(cbc_key, cbc_iv, cbc_ct)
assert bytes_equal(cbc_rt, cbc_pt),
  'AES-CBC round-trip must recover plaintext'
ok('round-trip (AES-256-CBC)')

# PKCS#7 padding — ciphertext must be a multiple of 16 bytes
assert cbc_ct.length() % 16 == 0,
  'AES-CBC ciphertext must be a multiple of the block size (16)'
ok('ciphertext length is a multiple of 16')

# AES-128
var cbc_key128 = crypto.random_bytes(16)
var cbc_ct128  = crypto.aes_cbc.encrypt(cbc_key128, cbc_iv, cbc_pt)
var cbc_rt128  = crypto.aes_cbc.decrypt(cbc_key128, cbc_iv, cbc_ct128)
assert bytes_equal(cbc_rt128, cbc_pt),
  'AES-128-CBC round-trip must recover plaintext'
ok('round-trip (AES-128-CBC)')

# Wrong key must fail (bad padding will cause decryption error)
assert raises(@() {
  crypto.aes_cbc.decrypt(cbc_key2, cbc_iv, cbc_ct)
}), 'AES-CBC must reject wrong key'
ok('wrong key raises exception')

# Plaintext exactly one block — tests boundary padding
var cbc_block_pt = '0123456789abcdef'.to_bytes()   # exactly 16 bytes
var cbc_block_ct = crypto.aes_cbc.encrypt(cbc_key, cbc_iv, cbc_block_pt)
var cbc_block_rt = crypto.aes_cbc.decrypt(cbc_key, cbc_iv, cbc_block_ct)
assert bytes_equal(cbc_block_rt, cbc_block_pt),
  'AES-CBC must handle plaintext exactly one block long'
ok('plaintext == one block (PKCS#7 full-block padding)')


# ===========================================================================
# 4. ChaCha20-Poly1305
# ===========================================================================
begin('ChaCha20-Poly1305')
summary()

var cc_pt   = 'ChaCha20-Poly1305 test vector — software crypto path'.to_bytes()
var cc_key  = crypto.random_bytes(32)
var cc_key2 = crypto.random_bytes(32)
var cc_iv   = crypto.random_bytes(12)
var cc_iv2  = crypto.random_bytes(12)

# Basic round-trip
var cc_ct = crypto.chacha20.encrypt(cc_key, cc_iv, cc_pt)
var cc_rt = crypto.chacha20.decrypt(cc_key, cc_iv, cc_ct)
assert bytes_equal(cc_rt, cc_pt),
  'ChaCha20 round-trip must recover plaintext'
ok('round-trip')

# Tag is appended
assert cc_ct.length() == cc_pt.length() + 16,
  'ChaCha20 ciphertext must be plaintext_len + 16'
ok('ciphertext length == plaintext + 16')

# Ciphertext differs from plaintext
assert !bytes_equal(cc_ct, cc_pt),
  'ChaCha20 ciphertext must differ from plaintext'
ok('ciphertext != plaintext')

# Different IV → different ciphertext
var cc_ct2 = crypto.chacha20.encrypt(cc_key, cc_iv2, cc_pt)
assert !bytes_equal(cc_ct, cc_ct2),
  'Different IVs must produce different ChaCha20 ciphertexts'
ok('distinct ciphertexts for distinct IVs')

# AAD correct
var cc_aad = 'chacha-aad-context'.to_bytes()
var cc_ct_aad = crypto.chacha20.encrypt(cc_key, cc_iv, cc_pt, cc_aad)
var cc_rt_aad = crypto.chacha20.decrypt(cc_key, cc_iv, cc_ct_aad, cc_aad)
assert bytes_equal(cc_rt_aad, cc_pt),
  'ChaCha20 with correct AAD must decrypt cleanly'
ok('AAD — correct AAD decrypts cleanly')

# AAD wrong
assert raises(@() {
  crypto.chacha20.decrypt(cc_key, cc_iv, cc_ct_aad, 'bad-aad'.to_bytes())
}), 'ChaCha20 must reject mismatched AAD'
ok('AAD — wrong AAD raises exception')

# Tampered ciphertext
var cc_tampered = cc_ct.clone()
cc_tampered[0] = cc_tampered[0] ^ 0xff
assert raises(@() {
  crypto.chacha20.decrypt(cc_key, cc_iv, cc_tampered)
}), 'ChaCha20 must reject tampered ciphertext'
ok('tampered ciphertext raises exception')

# Wrong key
assert raises(@() {
  crypto.chacha20.decrypt(cc_key2, cc_iv, cc_ct)
}), 'ChaCha20 must reject wrong key'
ok('wrong key raises exception')

# Empty plaintext
var cc_empty_ct = crypto.chacha20.encrypt(cc_key, cc_iv, bytes(0))
var cc_empty_rt = crypto.chacha20.decrypt(cc_key, cc_iv, cc_empty_ct)
assert cc_empty_rt.length() == 0,
  'ChaCha20 must handle empty plaintext'
ok('empty plaintext round-trip')


# ===========================================================================
# 5. RSA-2048
# ===========================================================================
begin('RSA-2048')
summary()

echo '  (RSA key generation may take a moment...)'

var rsa2k = crypto.rsa.generate(2048)

assert rsa2k != nil,
  'rsa.generate(2048) must return a dict'
ok('generate() returns a result')

assert rsa2k.contains('private_pem'),
  'RSA key dict must have private_pem'
ok('result contains private_pem')

assert rsa2k.contains('public_pem'),
  'RSA key dict must have public_pem'
ok('result contains public_pem')

assert rsa2k['private_pem'].starts_with('-----BEGIN'),
  'private_pem must be PEM-encoded'
ok('private_pem is valid PEM')

assert rsa2k['public_pem'].starts_with('-----BEGIN'),
  'public_pem must be PEM-encoded'
ok('public_pem is valid PEM')

# Keys must differ from each other
assert rsa2k['private_pem'] != rsa2k['public_pem'],
  'private_pem and public_pem must differ'
ok('private_pem != public_pem')

# OAEP encrypt / decrypt
var rsa_msg = 'RSA-OAEP test payload — 2048-bit'.to_bytes()
var rsa_ct  = crypto.rsa.encrypt(rsa2k['public_pem'], rsa_msg)
var rsa_rt  = crypto.rsa.decrypt(rsa2k['private_pem'], rsa_ct)

assert bytes_equal(rsa_rt, rsa_msg),
  'RSA-OAEP round-trip must recover plaintext'
ok('OAEP encrypt/decrypt round-trip')

# Ciphertext must differ from plaintext
assert !bytes_equal(rsa_ct, rsa_msg),
  'RSA ciphertext must differ from plaintext'
ok('ciphertext != plaintext')

# PSS sign / verify
var rsa_payload = 'document to authenticate with RSA-PSS'.to_bytes()
var rsa_sig     = crypto.rsa.sign(rsa2k['private_pem'], rsa_payload)
var rsa_valid   = crypto.rsa.verify(rsa2k['public_pem'], rsa_payload, rsa_sig)

assert rsa_valid,
  'RSA-PSS signature must verify against matching public key'
ok('PSS sign/verify — correct signature accepted')

# Wrong message must not verify
var rsa_wrong = crypto.rsa.verify(rsa2k['public_pem'], 'different message'.to_bytes(), rsa_sig)
assert !rsa_wrong,
  'RSA-PSS must reject signature for a different message'
ok('PSS verify — wrong message rejected')

# Cross-key pair — different key must not verify
var rsa2k_b   = crypto.rsa.generate(2048)
var rsa_cross = crypto.rsa.verify(rsa2k_b['public_pem'], rsa_payload, rsa_sig)
assert !rsa_cross,
  'RSA-PSS must reject signature verified against a different key pair'
ok('PSS verify — cross-keypair rejected')

# Decrypt with wrong private key must fail
assert raises(@() {
  crypto.rsa.decrypt(rsa2k_b['private_pem'], rsa_ct)
}), 'RSA-OAEP must fail when decrypted with wrong private key'
ok('OAEP decrypt with wrong key raises exception')


# ===========================================================================
# 6. RSA-4096
# ===========================================================================
begin('RSA-4096')
summary()

echo '  (RSA-4096 key generation takes several seconds — please wait...)'

var rsa4k = crypto.rsa.generate(4096)
assert rsa4k['private_pem'].starts_with('-----BEGIN'),
  'RSA-4096 generate must produce valid PEM'
ok('generate() produces valid PEM')

var rsa4k_payload = 'RSA-4096 PSS signing test'.to_bytes()
var rsa4k_sig     = crypto.rsa.sign(rsa4k['private_pem'], rsa4k_payload)
var rsa4k_ok      = crypto.rsa.verify(rsa4k['public_pem'], rsa4k_payload, rsa4k_sig)
assert rsa4k_ok,
  'RSA-4096-PSS sign/verify round-trip must succeed'
ok('PSS sign/verify round-trip (4096-bit)')

# 4096-bit signature must not verify under 2048-bit key
var rsa4k_cross = crypto.rsa.verify(rsa2k['public_pem'], rsa4k_payload, rsa4k_sig)
assert !rsa4k_cross,
  'RSA-4096 signature must not verify under a 2048-bit key'
ok('4096-bit signature rejected by 2048-bit key')


# ===========================================================================
# 7. ECDSA P-256
# ===========================================================================
begin('ECDSA P-256')
summary()

var ec256 = crypto.ecdsa.generate('P-256')

assert ec256.contains('private_pem') and ec256.contains('public_pem'),
  'ecdsa.generate() must return private_pem and public_pem'
ok('generate() returns valid key dict')

assert ec256['private_pem'].starts_with('-----BEGIN'),
  'P-256 private_pem must be PEM-encoded'
ok('private_pem is valid PEM')

var ec256_msg = 'ECDSA P-256 test message'.to_bytes()
var ec256_sig = crypto.ecdsa.sign(ec256['private_pem'], ec256_msg)

assert ec256_sig.length() > 0,
  'ecdsa.sign() must return a non-empty byte string'
ok('sign() returns non-empty bytes')

var ec256_ok = crypto.ecdsa.verify(ec256['public_pem'], ec256_msg, ec256_sig)
assert ec256_ok,
  'ECDSA P-256 signature must verify against matching public key'
ok('verify() accepts valid signature')

# Wrong message
var ec256_wrong_msg = crypto.ecdsa.verify(ec256['public_pem'], 'wrong'.to_bytes(), ec256_sig)
assert !ec256_wrong_msg,
  'ECDSA P-256 verify must reject signature for a different message'
ok('verify() rejects wrong message')

# Cross-key pair
var ec256_b     = crypto.ecdsa.generate('P-256')
var ec256_cross = crypto.ecdsa.verify(ec256_b['public_pem'], ec256_msg, ec256_sig)
assert !ec256_cross,
  'ECDSA P-256 verify must reject cross-keypair signature'
ok('verify() rejects cross-keypair signature')

# Two signatures of the same message with ECDSA should differ (probabilistic r)
var ec256_sig2 = crypto.ecdsa.sign(ec256['private_pem'], ec256_msg)
# Note: ECDSA is randomised, so this will virtually always be true.
# We verify both sigs are valid even though they differ.
var ec256_ok2 = crypto.ecdsa.verify(ec256['public_pem'], ec256_msg, ec256_sig2)
assert ec256_ok2,
  'Second independent ECDSA P-256 signature must also verify'
ok('two independent signatures both verify')


# ===========================================================================
# 8. ECDSA P-384
# ===========================================================================
begin('ECDSA P-384')
summary()

var ec384     = crypto.ecdsa.generate('P-384')
var ec384_msg = 'ECDSA P-384 test payload'.to_bytes()
var ec384_sig = crypto.ecdsa.sign(ec384['private_pem'], ec384_msg)
var ec384_ok  = crypto.ecdsa.verify(ec384['public_pem'], ec384_msg, ec384_sig)

assert ec384_ok,
  'ECDSA P-384 signature must verify against matching public key'
ok('sign/verify round-trip (P-384)')

# P-384 signature must not verify under P-256 key
var ec384_cross = crypto.ecdsa.verify(ec256['public_pem'], ec384_msg, ec384_sig)
assert !ec384_cross,
  'P-384 signature must not verify under P-256 key'
ok('P-384 signature rejected by P-256 key')

# Wrong message
assert !crypto.ecdsa.verify(ec384['public_pem'], 'nope'.to_bytes(), ec384_sig),
  'P-384 verify must reject wrong message'
ok('verify() rejects wrong message (P-384)')


# ===========================================================================
# 9. Ed25519
# ===========================================================================
begin('Ed25519')
summary()

var ed_kp  = crypto.ed25519.generate()
var ed_kp2 = crypto.ed25519.generate()

assert ed_kp.contains('private_pem') and ed_kp.contains('public_pem'),
  'ed25519.generate() must return private_pem and public_pem'
ok('generate() returns valid key dict')

# Two generate() calls must produce different keys
assert ed_kp['public_pem'] != ed_kp2['public_pem'],
  'Two ed25519.generate() calls must produce distinct keys'
ok('successive generate() calls produce distinct keys')

var ed_msg  = 'Ed25519 EdDSA test message — deterministic signature'.to_bytes()
var ed_sig  = crypto.ed25519.sign(ed_kp['private_pem'], ed_msg)
var ed_sig2 = crypto.ed25519.sign(ed_kp['private_pem'], ed_msg)

# Ed25519 is deterministic — identical inputs produce identical signatures
assert bytes_equal(ed_sig, ed_sig2),
  'Ed25519 must produce deterministic signatures'
ok('sign() is deterministic')

assert ed_sig.length() == 64,
  'Ed25519 signature must be exactly 64 bytes'
ok('signature is exactly 64 bytes')

var ed_ok = crypto.ed25519.verify(ed_kp['public_pem'], ed_msg, ed_sig)
assert ed_ok,
  'Ed25519 signature must verify against matching public key'
ok('verify() accepts valid signature')

# Wrong message
var ed_wrong_msg = crypto.ed25519.verify(ed_kp['public_pem'], 'tampered'.to_bytes(), ed_sig)
assert !ed_wrong_msg,
  'Ed25519 verify must reject wrong message'
ok('verify() rejects wrong message')

# Cross-keypair
var ed_cross = crypto.ed25519.verify(ed_kp2['public_pem'], ed_msg, ed_sig)
assert !ed_cross,
  'Ed25519 verify must reject cross-keypair signature'
ok('verify() rejects cross-keypair signature')

# Tampered signature (flip one byte)
var ed_tampered = ed_sig.clone()
ed_tampered[0] = ed_tampered[0] ^ 0x01
var ed_tampered_ok = crypto.ed25519.verify(ed_kp['public_pem'], ed_msg, ed_tampered)
assert !ed_tampered_ok,
  'Ed25519 verify must reject a tampered signature'
ok('verify() rejects tampered signature')


# ===========================================================================
# 10. X25519
# ===========================================================================
begin('X25519')
summary()

var alice = crypto.x25519.generate()
var bob   = crypto.x25519.generate()
var carol = crypto.x25519.generate()

assert alice.contains('private_pem') and alice.contains('public_pem'),
  'x25519.generate() must return private_pem and public_pem'
ok('generate() returns valid key dict')

# Core property: both parties must derive the same shared secret
var alice_secret = crypto.x25519.exchange(alice['private_pem'], bob['public_pem'])
var bob_secret   = crypto.x25519.exchange(bob['private_pem'],   alice['public_pem'])

assert bytes_equal(alice_secret, bob_secret),
  'X25519 exchange must produce identical shared secrets for both parties'
ok('shared secrets are equal for both parties')

assert alice_secret.length() == 32,
  'X25519 shared secret must be exactly 32 bytes'
ok('shared secret is exactly 32 bytes')

# Different peer → different shared secret
var alice_carol_secret = crypto.x25519.exchange(alice['private_pem'], carol['public_pem'])
assert !bytes_equal(alice_secret, alice_carol_secret),
  'X25519 exchange with a different peer must produce a different secret'
ok('different peer produces different shared secret')

# Shared secret must not equal either public key
var alice_pub_bytes = alice['public_pem']
assert !bytes_equal(alice_secret, alice_pub_bytes),
  'X25519 shared secret must not equal the local public key'
ok('shared secret != local public key')


# ===========================================================================
# 11. Argon2id
# ===========================================================================
begin('Argon2id')
summary()

var a2_password  = 'correct horse battery staple'
var a2_wrong_pw  = 'incorrect horse battery staple'
var a2_salt      = crypto.random_bytes(16)
var a2_salt2     = crypto.random_bytes(16)

var a2_hash = crypto.argon2.hash(a2_password, a2_salt)

assert is_string(a2_hash),
  'argon2.hash() must return a string'
ok('hash() returns a string')

assert a2_hash.starts_with('$argon2id$'),
  'argon2.hash() must return an argon2id encoded string'
ok('encoded string has $argon2id$ prefix')

# Correct password verifies
var a2_ok = crypto.argon2.verify(a2_hash, a2_password)
assert a2_ok,
  'argon2.verify() must accept the correct password'
ok('verify() accepts correct password')

# Wrong password does not verify
var a2_fail = crypto.argon2.verify(a2_hash, a2_wrong_pw)
assert !a2_fail,
  'argon2.verify() must reject a wrong password'
ok('verify() rejects wrong password')

# Different salts produce different hashes for the same password
var a2_hash2 = crypto.argon2.hash(a2_password, a2_salt2)
assert a2_hash != a2_hash2,
  'Different salts must produce different Argon2 hashes'
ok('different salts produce different hashes')

# Hash2 also verifies correctly with its own salt
assert crypto.argon2.verify(a2_hash2, a2_password),
  'argon2.verify() must work with a hash produced from a different salt'
ok('each hash verifies independently')

# Custom parameters
var a2_hash_custom = crypto.argon2.hash(a2_password, a2_salt, {
  t_cost: 2,
  m_cost: 8192,
  threads: 1,
  hash_len: 64,
})
assert is_string(a2_hash_custom),
  'argon2.hash() with custom options must return a string'
ok('custom options (t=2, m=8192, p=1, len=64) — hash returned')

assert crypto.argon2.verify(a2_hash_custom, a2_password),
  'argon2.verify() must accept hash produced with custom options'
ok('custom options hash verifies correctly')

# Empty password is valid (unusual but must not crash)
var a2_empty_hash = crypto.argon2.hash('', a2_salt)
assert crypto.argon2.verify(a2_empty_hash, ''),
  'argon2 must handle empty password'
ok('empty password round-trip')

# Cross-hash check: hash1 must not verify with wrong password from hash2
assert !crypto.argon2.verify(a2_hash, a2_wrong_pw),
  'argon2.verify() must not accept wrong password against first hash'
ok('cross-hash password rejection')


# ===========================================================================
# 12. HKDF
# ===========================================================================
begin('HKDF-SHA256')
summary()

var hkdf_ikm  = crypto.random_bytes(32)
var hkdf_salt = crypto.random_bytes(32)
var hkdf_info = 'zuri-crypto-test-context-v1'.to_bytes()

var hkdf_k32 = crypto.hkdf(hkdf_ikm, hkdf_salt, hkdf_info, 32)
var hkdf_k64 = crypto.hkdf(hkdf_ikm, hkdf_salt, hkdf_info, 64)
var hkdf_k16 = crypto.hkdf(hkdf_ikm, hkdf_salt, hkdf_info, 16)

assert hkdf_k32.length() == 32,
  'hkdf() must return the requested number of bytes (32)'
ok('output length == 32')

assert hkdf_k64.length() == 64,
  'hkdf() must return the requested number of bytes (64)'
ok('output length == 64')

assert hkdf_k16.length() == 16,
  'hkdf() must return the requested number of bytes (16)'
ok('output length == 16')

# Deterministic: same inputs → same output
var hkdf_k32_b = crypto.hkdf(hkdf_ikm, hkdf_salt, hkdf_info, 32)
assert bytes_equal(hkdf_k32, hkdf_k32_b),
  'hkdf() must be deterministic for identical inputs'
ok('deterministic output for identical inputs')

# Different info → different key
var hkdf_k32_enc  = crypto.hkdf(hkdf_ikm, hkdf_salt, 'encryption'.to_bytes(), 32)
var hkdf_k32_auth = crypto.hkdf(hkdf_ikm, hkdf_salt, 'authentication'.to_bytes(), 32)
assert !bytes_equal(hkdf_k32_enc, hkdf_k32_auth),
  'hkdf() must produce distinct keys for distinct info values'
ok('different info strings produce distinct keys')

# Different salt → different key
var hkdf_salt2   = crypto.random_bytes(32)
var hkdf_k32_s2  = crypto.hkdf(hkdf_ikm, hkdf_salt2, hkdf_info, 32)
assert !bytes_equal(hkdf_k32, hkdf_k32_s2),
  'hkdf() must produce distinct keys for distinct salts'
ok('different salts produce distinct keys')

# Different IKM → different key
var hkdf_ikm2   = crypto.random_bytes(32)
var hkdf_k32_i2 = crypto.hkdf(hkdf_ikm2, hkdf_salt, hkdf_info, 32)
assert !bytes_equal(hkdf_k32, hkdf_k32_i2),
  'hkdf() must produce distinct keys for distinct IKMs'
ok('different IKMs produce distinct keys')

# Output must not equal the IKM
assert !bytes_equal(hkdf_k32, hkdf_ikm),
  'hkdf() output must not equal the raw IKM'
ok('output != raw IKM')


# ===========================================================================
# 13. Cross-primitive integration
#     X25519 → HKDF → AES-GCM (the canonical key-agreement + encryption flow)
# ===========================================================================
begin('Integration: X25519 → HKDF → AES-GCM')
summary()

# Alice and Bob each generate an X25519 key pair (done above — reuse)
var int_salt       = crypto.random_bytes(32)
var int_info_enc   = 'zuri-session-encryption-key'.to_bytes()
var int_info_auth  = 'zuri-session-auth-key'.to_bytes()

# Both parties derive the shared secret
var int_alice_secret = crypto.x25519.exchange(alice['private_pem'], bob['public_pem'])
var int_bob_secret   = crypto.x25519.exchange(bob['private_pem'],   alice['public_pem'])

assert bytes_equal(int_alice_secret, int_bob_secret),
  'Integration: shared secrets must agree'
ok('shared secret agreement')

# Derive a 32-byte AES-256 encryption key from the shared secret
var int_alice_enc_key = crypto.hkdf(int_alice_secret, int_salt, int_info_enc, 32)
var int_bob_enc_key   = crypto.hkdf(int_bob_secret,   int_salt, int_info_enc, 32)

assert bytes_equal(int_alice_enc_key, int_bob_enc_key),
  'Integration: derived encryption keys must be equal'
ok('derived encryption keys are equal')

# Alice encrypts a message to Bob
var int_plaintext = 'session message: authenticated key-agreement works end-to-end'.to_bytes()
var int_iv        = crypto.random_bytes(12)
var int_ct        = crypto.aes_gcm.encrypt(int_alice_enc_key, int_iv, int_plaintext)

# Bob decrypts using his independently derived key
var int_rt = crypto.aes_gcm.decrypt(int_bob_enc_key, int_iv, int_ct)
assert bytes_equal(int_rt, int_plaintext),
  'Integration: Bob must recover Alice\'s plaintext'
ok('end-to-end: Bob decrypts Alice\'s message')

# Carol (third party) cannot decrypt — her secret with Alice differs
var int_carol_secret  = crypto.x25519.exchange(carol['private_pem'], alice['public_pem'])
var int_carol_enc_key = crypto.hkdf(int_carol_secret, int_salt, int_info_enc, 32)

assert raises(@() {
  crypto.aes_gcm.decrypt(int_carol_enc_key, int_iv, int_ct)
}), 'Integration: third party must not be able to decrypt the session message'
ok('third party (Carol) cannot decrypt — authentication fails')


# ===========================================================================
# 14. Invalid argument handling
# ===========================================================================
begin('Invalid argument handling')
summary()

# random_bytes: zero length
assert raises(@() { crypto.random_bytes(0) }),
  'random_bytes(0) must raise'
ok('random_bytes(0) raises')

# random_bytes: over maximum
assert raises(@() { crypto.random_bytes(65537) }),
  'random_bytes(65537) must raise'
ok('random_bytes(65537) raises')

# AES-GCM: bad key size
assert raises(@() {
  crypto.aes_gcm.encrypt(crypto.random_bytes(10), crypto.random_bytes(12), 'x'.to_bytes())
}), 'aes_gcm.encrypt() must reject a key that is not 16/24/32 bytes'
ok('aes_gcm.encrypt() rejects bad key size')

# AES-GCM: IV too short (0 bytes — GCM minimum is 1, OpenSSL will reject)
assert raises(@() {
  crypto.aes_gcm.encrypt(crypto.random_bytes(32), bytes(''), 'x'.to_bytes())
}), 'aes_gcm.encrypt() must reject a zero-length IV'
ok('aes_gcm.encrypt() rejects zero-length IV')

# AES-CBC: IV must be exactly 16 bytes
assert raises(@() {
  crypto.aes_cbc.encrypt(crypto.random_bytes(32), crypto.random_bytes(8), 'x'.to_bytes())
}), 'aes_cbc.encrypt() must reject IV != 16 bytes'
ok('aes_cbc.encrypt() rejects IV of wrong length')

# ChaCha20: key must be 32 bytes
assert raises(@() {
  crypto.chacha20.encrypt(crypto.random_bytes(16), crypto.random_bytes(12), 'x'.to_bytes())
}), 'chacha20.encrypt() must reject key != 32 bytes'
ok('chacha20.encrypt() rejects bad key size')

# ChaCha20: IV must be 12 bytes
assert raises(@() {
  crypto.chacha20.encrypt(crypto.random_bytes(32), crypto.random_bytes(8), 'x'.to_bytes())
}), 'chacha20.encrypt() must reject nonce != 12 bytes'
ok('chacha20.encrypt() rejects bad nonce size')

# RSA: invalid bit count
assert raises(@() { crypto.rsa.generate(1024) }),
  'rsa.generate() must reject bit counts other than 2048/4096'
ok('rsa.generate(1024) raises')

assert raises(@() { crypto.rsa.generate(3072) }),
  'rsa.generate(3072) must raise'
ok('rsa.generate(3072) raises')

# ECDSA: unknown curve
assert raises(@() { crypto.ecdsa.generate('P-521') }),
  'ecdsa.generate() must reject unknown curves'
ok('ecdsa.generate("P-521") raises')

# Argon2: salt too short
assert raises(@() {
  crypto.argon2.hash('password', crypto.random_bytes(4))
}), 'argon2.hash() must reject salt shorter than 8 bytes'
ok('argon2.hash() rejects salt < 8 bytes')

# HKDF: zero output length
assert raises(@() {
  crypto.hkdf(crypto.random_bytes(32), crypto.random_bytes(32), 'x'.to_bytes(), 0)
}), 'hkdf() must reject length == 0'
ok('hkdf() rejects length == 0')

# HKDF: output length over maximum
assert raises(@() {
  crypto.hkdf(crypto.random_bytes(32), crypto.random_bytes(32), 'x'.to_bytes(), 8161)
}), 'hkdf() must reject length > 8160'
ok('hkdf() rejects length > 8160')


