import os
import io
import args
import test.conductor
import log
import ..setup

def parse(parser) {
  parser.add_command(
    'run',
    'Run a zuri project or script',
    {
      type: args.STRING,
      value: 'index.zu'
    }
  )
}

def run(value, options, success, error) {
  catch {
    conductor.conduct(setup.TEST_DIR)
  } as error
  if error {
    echo error.message
  }
}
